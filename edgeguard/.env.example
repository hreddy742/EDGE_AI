MODE=general_shopfloor
VIDEO_SOURCE_TYPE=file
VIDEO_FILE_PATH=./data/videos/sample.mp4
RTSP_URL=rtsp://user:pass@127.0.0.1:554/stream
CAMERA_ID=cam01
CAMERA_ROLE=AISLE
ZONES_PATH=./config/zones.sample.json
MULTI_CAMERA_CONFIG_PATH=./config/cameras.sample.json

FRAME_FPS=12
STREAM_JPEG_MAX_FPS=30
DROP_FRAMES_WHEN_LAGGING=true
RTSP_TRANSPORT=tcp
RTSP_OPEN_TIMEOUT_MS=8000
RTSP_READ_TIMEOUT_MS=8000
RTSP_BUFFER_SIZE=1
MODEL_NAME=yolo26n.pt
POSE_MODEL_NAME=yolo26n-pose.pt
CONF_THRES=0.35
IOU_THRES=0.5
USE_BYTETRACK=true
CROSS_CAMERA_REID_ENABLED=false

RISK_THRESHOLD=8
N_FRAMES_HAND_IN_SHELF=4
CONCEAL_WINDOW_SEC=4
EVENT_COOLDOWN_SECONDS=20
HAND_TO_HIP_DISTANCE_PX=110
WRIST_ZONE_CONF_THRES=0.20

DB_URL=sqlite:///./edgeguard.db
SNAPSHOT_DIR=./data/snapshots
CLIP_DIR=./data/clips
DEBUG_DUMP_DIR=./data/debug
THEFT_CLIP_SECONDS_BEFORE=2
THEFT_CLIP_SECONDS_AFTER=3
THEFT_ALERT_SECONDS=4

RUN_PIPELINE_ON_STARTUP=true
API_BASE_URL=http://127.0.0.1:8000
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SEC=3
